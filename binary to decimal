#include<stdio.h>
#include<math.h>

int main(){
  int n;int i=0;
  int decimal=0,remainder;

  printf("Enter number: ");
  scanf("%d", &n);

  while(n!=0){
    remainder = n%10;
    decimal=decimal+remainder*pow(2,i);
    n=n/10;
    i++;

  }
  
  printf("binary to decimal is  %d",decimal);
    
  return 0;
}
