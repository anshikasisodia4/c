#include<stdio.h>
int main(){
    int n ,result=0,place=1,digit;
    printf("enter number:");
    scanf("%d",&n);

    while(n!=0){
        digit=n%10;
        if(digit==0){
            digit=1;
        }
        result=result +digit*place;
        place=place*10;
        n=n/10;
    }printf("number after replacing 0 with 1: %d",result);
     return 0;
}
