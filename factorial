#include<stdio.h>

     int main(){
        int  n,i;
        long long factorial =1;
        printf("enter number:");
        scanf("%d",&n);
        if(n==0){
            printf("factorial does not exist");
        }else{
            for(i=1;i<=n;i++){
                factorial=factorial*i;
            }printf("factorial is %d",factorial);
            
        }
        return 0;
     }
