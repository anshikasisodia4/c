#include<stdio.h>

     int main(){
        int n,i;
        int sumE;
        int sumO;
        printf("enter number:");
        scanf("%d",&n);
        for(i=0;i<=n;i++){
            if(i%2==0){
                sumE=sumE+i;
            }else{
                 sumO=sumO+i;
            }
        }
        printf("sum of even numbers is %d\n",sumE);
        printf("sum of odd numbers is %d\n",sumO);

      return 0;
     }
